---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Kyle Thumm for consulting inquiries, marketing audits, or general questions."
>
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-16">
        <!-- Form side -->
        <div>
          <div class="mb-10 fade-in">
            <p class="text-xs font-mono font-medium uppercase tracking-widest text-[--color-accent] mb-3">Contact</p>
            <h1 class="text-3xl md:text-5xl font-bold tracking-tight leading-tight mb-4">Let's talk.</h1>
            <p class="text-lg text-[--color-text-secondary] leading-relaxed max-w-lg">
              Whether you need a full marketing system built from scratch or just want a second opinion on your current setup, I am happy to chat.
            </p>
          </div>

          <div class="fade-in">
            <ContactForm />
          </div>
        </div>

        <!-- Info side -->
        <div class="fade-in">
          <div class="rounded-2xl border border-[--color-border] bg-[--color-surface] p-6 mb-6">
            <h3 class="text-sm font-bold text-[--color-text-primary] mb-3">What to expect</h3>
            <ul class="space-y-3">
              <li class="flex gap-3 text-sm text-[--color-text-secondary]">
                <span class="text-[--color-accent] mt-0.5 shrink-0">1.</span>
                I will respond within 24 hours, usually faster.
              </li>
              <li class="flex gap-3 text-sm text-[--color-text-secondary]">
                <span class="text-[--color-accent] mt-0.5 shrink-0">2.</span>
                We will hop on a quick call to understand your business and goals.
              </li>
              <li class="flex gap-3 text-sm text-[--color-text-secondary]">
                <span class="text-[--color-accent] mt-0.5 shrink-0">3.</span>
                I will put together a recommendation -- no hard sell, no commitment.
              </li>
            </ul>
          </div>

          <div class="rounded-2xl border border-[--color-border] bg-[--color-surface] p-6 mb-6">
            <h3 class="text-sm font-bold text-[--color-text-primary] mb-3">Direct contact</h3>
            <div class="space-y-3">
              <a href="mailto:kylethumm@gmail.com" class="flex items-center gap-3 text-sm text-[--color-text-secondary] hover:text-[--color-accent] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                kylethumm@gmail.com
              </a>
              <a href="https://www.linkedin.com/in/kylethumm" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[--color-text-secondary] hover:text-[--color-accent] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                linkedin.com/in/kylethumm
              </a>
              <a href="https://x.com/kylethumm" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[--color-text-secondary] hover:text-[--color-accent] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                @kylethumm
              </a>
            </div>
          </div>

          <div class="rounded-2xl border border-[--color-border] bg-[--color-surface] p-6">
            <h3 class="text-sm font-bold text-[--color-text-primary] mb-2">Based in</h3>
            <p class="text-sm text-[--color-text-secondary]">Huntsville, Alabama</p>
            <p class="text-xs text-[--color-text-dim] mt-1">Working with clients nationally</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
