---
const items = [
  {
    title: 'Paid Media',
    desc: 'Google Ads, Meta, YouTube, Demand Gen. Multi-state, multi-language campaign architecture at scale.',
    icon: '<circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>',
    span: 'md:col-span-2',
  },
  {
    title: 'Marketing Automation',
    desc: 'GoHighLevel, Make.com, ActiveProspect. Full CRM builds, automated follow-up, AI-powered workflows.',
    icon: '<path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/><circle cx="12" cy="12" r="4"/>',
    span: '',
  },
  {
    title: 'Sales Team Enablement',
    desc: 'Dashboards, ClickUp workflows, comp plan design, leaderboards. Systems that turn leads into closed deals.',
    icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>',
    span: '',
  },
  {
    title: 'Local & Multi-Location',
    desc: '285 zip codes across 3 states. Spanish-language campaigns. Market-specific landing pages and funnels.',
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    span: '',
  },
  {
    title: 'AI & Automation',
    desc: 'AI-powered lead scoring, automated vendor management, intelligent routing and qualification workflows.',
    icon: '<path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/>',
    span: 'md:col-span-2',
  },
  {
    title: 'Conversion Optimization',
    desc: 'Landing pages, quiz funnels, qualification surveys. Fast-loading, mobile-first, built to convert.',
    icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
    span: '',
  },
];
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 fade-in">
      <p class="text-xs font-mono font-medium uppercase tracking-widest text-[--color-accent] mb-3">What I Do</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">The full marketing stack.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {items.map(item => (
        <div class:list={[
          'group relative rounded-2xl border border-[--color-border] bg-[--color-surface] p-6 md:p-8 transition-all duration-200 hover:border-[--color-accent]/20 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-[--color-accent]/5 fade-in',
          item.span,
        ]}>
          <div class="w-10 h-10 rounded-xl bg-[--color-accent-dim] flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[--color-accent]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={item.icon} />
          </div>
          <h3 class="text-lg font-bold text-[--color-text-primary] mb-2">{item.title}</h3>
          <p class="text-sm text-[--color-text-secondary] leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
