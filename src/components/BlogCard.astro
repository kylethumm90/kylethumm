---
interface Props {
  slug: string;
  title: string;
  date: Date;
  description: string;
  category: string;
}

const { slug, title, date, description, category } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Rough reading time estimate
const readTime = '5 min read';
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col rounded-2xl border border-[--color-border] bg-[--color-surface] p-6 transition-all duration-200 hover:border-[--color-accent]/20 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-[--color-accent]/5"
>
  <div class="flex items-center gap-3 mb-3">
    <span class="text-xs font-mono font-medium text-[--color-accent] uppercase tracking-wider">{category}</span>
    <span class="text-xs text-[--color-text-dim]">&middot;</span>
    <span class="text-xs text-[--color-text-dim]">{formattedDate}</span>
    <span class="text-xs text-[--color-text-dim]">&middot;</span>
    <span class="text-xs text-[--color-text-dim]">{readTime}</span>
  </div>
  <h3 class="text-lg font-bold text-[--color-text-primary] mb-2 group-hover:text-[--color-accent] transition-colors">{title}</h3>
  <p class="text-sm text-[--color-text-secondary] leading-relaxed flex-1">{description}</p>
  <div class="mt-4 flex items-center gap-1 text-sm font-medium text-[--color-accent]">
    Read More
    <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7" /></svg>
  </div>
</a>
