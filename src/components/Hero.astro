---
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[--color-accent]/10 rounded-full blur-[128px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-[--color-accent]/5 rounded-full blur-[96px]"></div>
  </div>

  <div class="mx-auto max-w-[1200px] px-6 py-24 md:py-32">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-[--color-border] bg-[--color-surface] px-4 py-2 text-sm text-[--color-text-secondary] mb-8">
        <span class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)] animate-pulse"></span>
        Head of Marketing & Growth
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6">
        I turn home service companies into
        <span class="bg-gradient-to-r from-[--color-accent] to-blue-400 bg-clip-text text-transparent">lead generation machines.</span>
      </h1>

      <!-- Subtext -->
      <p class="text-lg md:text-xl text-[--color-text-secondary] max-w-xl mb-10 leading-relaxed">
        Marketing leader running a $35M+ operation across solar, roofing, and HVAC.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="/work"
          class="inline-flex items-center gap-2 h-12 px-7 rounded-lg bg-[--color-accent] text-white font-semibold text-sm hover:bg-[--color-accent-hover] transition-all hover:-translate-y-0.5 shadow-lg shadow-[--color-accent]/20"
        >
          See My Work
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7" /></svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 h-12 px-7 rounded-lg border border-[--color-border] text-[--color-text-primary] font-semibold text-sm hover:bg-[--color-surface] transition-all hover:-translate-y-0.5"
        >
          Get In Touch
        </a>
      </div>
    </div>
  </div>
</section>
