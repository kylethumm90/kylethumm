---
const stats = [
  { number: '$35M+', label: 'Revenue managed' },
  { number: '285', label: 'Zip codes targeted' },
  { number: '13', label: 'Person sales team led' },
  { number: '2x', label: 'Deal volume in 12 months' },
  { number: '72%', label: 'Cost-per-sale reduction' },
];
---

<section class="border-y border-[--color-border] bg-[--color-surface]/50">
  <div class="mx-auto max-w-[1200px] px-6 py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-6">
      {stats.map(stat => (
        <div class="text-center fade-in">
          <div class="text-3xl md:text-4xl font-extrabold text-[--color-accent] tracking-tight leading-none mb-2">
            {stat.number}
          </div>
          <div class="text-xs md:text-sm text-[--color-text-dim] uppercase tracking-wider font-medium">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
