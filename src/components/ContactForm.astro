---
---

<form class="space-y-5" action="#contact-form" method="POST">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-sm font-medium text-[--color-text-primary] mb-2">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full h-11 px-4 text-sm rounded-lg border border-[--color-border] bg-[--color-surface] text-[--color-text-primary] placeholder:text-[--color-text-dim] focus:outline-none focus:border-[--color-accent] transition-colors"
        placeholder="Your name"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-[--color-text-primary] mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full h-11 px-4 text-sm rounded-lg border border-[--color-border] bg-[--color-surface] text-[--color-text-primary] placeholder:text-[--color-text-dim] focus:outline-none focus:border-[--color-accent] transition-colors"
        placeholder="you@company.com"
      />
    </div>
  </div>
  <div>
    <label for="company" class="block text-sm font-medium text-[--color-text-primary] mb-2">Company</label>
    <input
      type="text"
      id="company"
      name="company"
      class="w-full h-11 px-4 text-sm rounded-lg border border-[--color-border] bg-[--color-surface] text-[--color-text-primary] placeholder:text-[--color-text-dim] focus:outline-none focus:border-[--color-accent] transition-colors"
      placeholder="Your company name"
    />
  </div>
  <div>
    <label for="message" class="block text-sm font-medium text-[--color-text-primary] mb-2">Message</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 text-sm rounded-lg border border-[--color-border] bg-[--color-surface] text-[--color-text-primary] placeholder:text-[--color-text-dim] focus:outline-none focus:border-[--color-accent] transition-colors resize-none"
      placeholder="Tell me about your business and what you need help with"
    ></textarea>
  </div>
  <button
    type="submit"
    class="h-11 px-8 text-sm font-semibold rounded-lg bg-[--color-accent] text-white hover:bg-[--color-accent-hover] transition-all hover:-translate-y-0.5 shadow-lg shadow-[--color-accent]/20 cursor-pointer"
  >
    Send Message
  </button>
</form>
